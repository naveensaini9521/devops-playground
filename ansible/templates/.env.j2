# Application Configuration
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY={{ lookup('password', '/dev/null chars=ascii_letters,digits length=32') }}
DEBUG=False

# Database Configuration
{% if groups['role_master'] is defined and groups['role_master'] | length > 0 %}
DATABASE_URL=mysql://{{ db_username }}:{{ db_password }}@{{ hostvars[groups['role_master'][0]].private_ip_address }}/{{ db_name }}
DATABASE_HOST={{ hostvars[groups['role_master'][0]].private_ip_address }}
DATABASE_USER={{ db_username }}
DATABASE_PASSWORD={{ db_password }}
DATABASE_NAME={{ db_name }}
{% endif %}


# Application Configuration
DEBUG=False
LOG_LEVEL=INFO
MAX_CRAWL_DEPTH=3
CRAWL_TIMEOUT=30

# Additional settings
PYTHONUNBUFFERED=1
TZ=Asia/Kolkata