# Application Configuration
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY={{ lookup('password', '/dev/null chars=ascii_letters,digits length=32') }}
DEBUG=False
PORT=8000

# Database Configuration
{% if groups['role_master'] is defined and groups['role_master'] | length > 0 %}
MYSQL_HOST={{ hostvars[groups['role_master'][0]].private_ip_address }}
MYSQL_USERNAME={{ db_username }}
MYSQL_PASSWORD={{ db_password }}
MYSQL_DATABASE={{ db_name }}

DATABASE_URL=mysql+pymysql://{{ db_username }}:{{ db_password }}@{{ hostvars[groups['role_master'][0]].private_ip_address }}/{{ db_name }}
{% endif %}

# Application Settings
LOG_LEVEL=INFO
MAX_CRAWL_DEPTH=3
CRAWL_TIMEOUT=30

# Additional Settings
PYTHONUNBUFFERED=1
TZ=Asia/Kolkata